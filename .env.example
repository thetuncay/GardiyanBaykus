DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_DEV_GUILD_ID=

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/baykusbot?retryWrites=true&w=majority&appName=baykusbot
REDIS_URL=redis://localhost:6379

COMMAND_REGISTER_GUILD_ONLY=true
LOG_LEVEL=info
PORT=3000

BOT_OWNER_ID=YOUR_DISCORD_USER_ID

# İlk kurulum: botun otomatik izin alacağı sunucu ID'leri (virgülle ayır)
SEED_GUILD_IDS=
